{
  "name": "@fleet-management/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "seed:dev": "npm run build && ts-node scripts/seed-development.ts"
  },
  "dependencies": {
    "@nestjs/common": "latest",
    "@nestjs/config": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/websockets": "^11.1.28",
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/client": "latest",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "multer": "^2.2.0",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@eslint/js": "9.39.2",
    "@nestjs/cli": "latest",
    "@nestjs/schematics": "latest",
    "@nestjs/testing": "latest",
    "@types/multer": "^2.2.0",
    "@types/node": "latest",
    "eslint": "9.39.5",
    "eslint-config-prettier": "latest",
    "globals": "latest",
    "prisma": "latest",
    "source-map-support": "latest",
    "ts-loader": "latest",
    "ts-node": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "latest"
  }
}
